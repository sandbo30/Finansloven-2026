<!DOCTYPE html>
<html lang="da">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Finanslov 2026 — Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --navy:#1C3664;--navy2:#2B5CA8;--blue:#4E7FC4;--teal:#1D9E75;
  --gold:#C8A432;--red:#C0272D;--bg:#F0F4FB;--surface:#FFFFFF;
  --border:rgba(28,54,100,.11);--text:#18243E;--text2:#5C6B8A;--text3:#9AA3B7;
  --sw:256px;
}
body{font-family:'IBM Plex Sans','Helvetica Neue',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:14px;line-height:1.5;}
.shell{display:flex;flex-direction:column;height:100vh;overflow:hidden;}

.topbar{background:var(--navy);height:54px;padding:0 22px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;z-index:50;}
.topbar-left{display:flex;align-items:center;gap:12px;}
.logo{width:26px;height:26px;background:var(--gold);border-radius:5px;display:flex;align-items:center;justify-content:center;}
.topbar-title{font-family:'DM Serif Display',Georgia,serif;font-size:17px;color:#fff;letter-spacing:.01em;}
.topbar-right{font-size:11px;color:rgba(255,255,255,.45);letter-spacing:.04em;text-transform:uppercase;}

.layout{display:flex;flex:1;overflow:hidden;}

/* ── SIDEBAR ── */
.sidebar{width:var(--sw);background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;overflow:hidden;}
.sb-header{padding:16px 14px 12px;border-bottom:1px solid var(--border);}
.sb-header-title{font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:8px;}
.sb-overview-btn{width:100%;padding:7px 10px;border:1px solid var(--border);border-radius:7px;font-size:13px;font-family:inherit;background:transparent;color:var(--text2);cursor:pointer;text-align:left;transition:all .15s;display:flex;align-items:center;gap:7px;}
.sb-overview-btn:hover{background:var(--bg);}
.sb-overview-btn.on{background:var(--navy);color:#fff;border-color:var(--navy);}
.sb-list{flex:1;overflow-y:auto;padding:6px 0;}
.sb-item{padding:8px 14px;cursor:pointer;display:flex;align-items:center;gap:9px;border-left:3px solid transparent;transition:background .1s;}
.sb-item:hover{background:var(--bg);}
.sb-item.on{background:#EBF0F9;border-left-color:var(--navy);}
.sb-para-badge{font-size:10px;font-weight:500;color:var(--text3);min-width:28px;flex-shrink:0;font-variant-numeric:tabular-nums;}
.sb-info{flex:1;min-width:0;}
.sb-name{font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sb-val{font-size:11px;color:var(--text3);margin-top:1px;}
.sb-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:1px;}
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-thumb{background:rgba(28,54,100,.15);border-radius:10px;}

/* ── MAIN ── */
.main{flex:1;overflow-y:auto;padding:22px 24px;}

/* ── CARDS ── */
.metric-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(148px,1fr));gap:10px;margin-bottom:16px;}
.metric-card{background:var(--surface);border-radius:10px;padding:14px 15px;border:1px solid var(--border);}
.metric-label{font-size:10px;color:var(--text2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;}
.metric-val{font-family:'DM Serif Display',Georgia,serif;font-size:25px;color:var(--text);line-height:1.1;}
.metric-sub{font-size:11px;color:var(--text3);margin-top:2px;}

.card{background:var(--surface);border-radius:10px;border:1px solid var(--border);padding:19px;margin-bottom:14px;}
.card-title{font-size:14px;font-weight:500;color:var(--text);margin-bottom:3px;}
.card-sub{font-size:12px;color:var(--text2);margin-bottom:14px;}
.chart-row{display:grid;grid-template-columns:1fr 1.6fr;gap:14px;margin-bottom:14px;}

/* ── OVERVIEW HEADER ── */
.ov-title{font-family:'DM Serif Display',Georgia,serif;font-size:22px;color:var(--text);margin-bottom:3px;}
.ov-sub{font-size:12px;color:var(--text2);margin-bottom:16px;}

/* ── DETAIL ── */
.back-btn{display:flex;align-items:center;gap:5px;font-size:13px;color:var(--text2);cursor:pointer;background:none;border:none;font-family:inherit;padding:0;margin-bottom:14px;transition:color .15s;}
.back-btn:hover{color:var(--navy);}
.det-para{font-size:10px;font-weight:500;color:var(--text3);letter-spacing:.08em;text-transform:uppercase;margin-bottom:3px;}
.det-name{font-family:'DM Serif Display',Georgia,serif;font-size:24px;color:var(--text);line-height:1.2;margin-bottom:8px;}
.det-tags{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:18px;}
.tag{padding:3px 10px;border-radius:20px;font-size:11px;border:1px solid var(--border);color:var(--text2);background:var(--bg);}

/* ── BREAKDOWN BAR ── */
.bkd-bar{height:18px;border-radius:4px;overflow:hidden;display:flex;margin:10px 0;}
.bkd-seg{transition:width .4s ease;}
.bkd-legend{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:8px;}
.legend-item{display:flex;align-items:center;gap:7px;font-size:12px;}
.legend-dot{width:10px;height:10px;border-radius:2px;flex-shrink:0;}
.legend-name{color:var(--text2);flex:1;}
.legend-amt{font-weight:500;color:var(--text);}

/* ── SUB TABLE ── */
.sub-table{width:100%;border-collapse:collapse;}
.sub-table th{font-size:10px;text-transform:uppercase;letter-spacing:.05em;color:var(--text3);padding:6px 8px;text-align:left;border-bottom:1px solid var(--border);}
.sub-table th:last-child{text-align:right;}
.sub-table td{padding:9px 8px;font-size:13px;border-bottom:1px solid var(--border);}
.sub-table td:last-child{text-align:right;font-weight:500;}
.sub-table tr:last-child td{border-bottom:none;}
.bar-outer{height:5px;background:var(--bg);border-radius:3px;margin-top:3px;overflow:hidden;}
.bar-inner{height:5px;border-radius:3px;}

/* ── NOTES AND METADATA ── */
.note{background:#EBF0F9;border-left:3px solid var(--navy2);border-radius:0 6px 6px 0;padding:10px 13px;font-size:12px;color:var(--text2);line-height:1.65;margin-top:12px;}
.meta-box{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px 19px;margin-top:14px;}
.meta-title{font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:10px;}
.meta-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;}
.meta-item{}
.meta-key{font-size:11px;font-weight:500;color:var(--text2);margin-bottom:2px;}
.meta-val{font-size:12px;color:var(--text);line-height:1.55;}
.meta-formula{font-family:'IBM Plex Mono',monospace;font-size:11px;background:var(--bg);border:1px solid var(--border);border-radius:5px;padding:6px 10px;margin-top:6px;color:var(--text);}

/* ── PROJECTION TABLE ── */
.proj-table{width:100%;border-collapse:collapse;font-size:13px;}
.proj-table th{font-size:10px;text-transform:uppercase;letter-spacing:.05em;color:var(--text3);padding:5px 8px;border-bottom:1px solid var(--border);text-align:right;}
.proj-table th:first-child{text-align:left;}
.proj-table td{padding:8px;border-bottom:1px solid var(--border);text-align:right;}
.proj-table td:first-child{text-align:left;}
.proj-table .hl td{font-weight:500;background:#EBF0F9;}
.proj-table tr:last-child td{border-bottom:none;}

.fade{animation:fadeUp .2s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(5px);}to{opacity:1;transform:translateY(0);}}

/* ── TOGGLE BUTTONS ── */
.toggle-btn{padding:4px 11px;border-radius:20px;font-size:11px;font-family:inherit;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--text2);transition:all .15s;white-space:nowrap;}
.toggle-btn:hover{background:var(--bg);}
.toggle-btn.on{background:var(--navy);color:#fff;border-color:var(--navy);}

/* ── SKRÆNTER (bevillingsudløb) ── */
.cliff-grid{display:flex;flex-direction:column;gap:8px;}
.cliff-item{border:1px solid var(--border);border-radius:8px;overflow:hidden;}
.cliff-header{display:flex;align-items:flex-start;gap:0;cursor:pointer;padding:12px 14px;transition:background .1s;}
.cliff-header:hover{background:var(--bg);}
.cliff-badge{flex-shrink:0;margin-right:10px;margin-top:2px;}
.cliff-badge span{display:inline-block;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:500;letter-spacing:.03em;}
.cliff-badge.ophør span{background:#FEF0EE;color:#993C1D;border:1px solid #F0997B;}
.cliff-badge.udløb span{background:#EBF0F9;color:#185FA5;border:1px solid #85B7EB;}
.cliff-badge.bortfald span{background:#FFF7E6;color:#854F0B;border:1px solid #EF9F27;}
.cliff-badge.afskaffelse span{background:#FEECF0;color:#993556;border:1px solid #ED93B1;}
.cliff-badge.annullering span{background:#F3F0FE;color:#534AB7;border:1px solid #AFA9EC;}
.cliff-main{flex:1;min-width:0;}
.cliff-name{font-size:13px;font-weight:500;color:var(--text);line-height:1.4;}
.cliff-meta{display:flex;gap:14px;margin-top:3px;flex-wrap:wrap;}
.cliff-amt{font-size:12px;color:var(--text2);}
.cliff-year{font-size:12px;color:var(--text3);}
.cliff-chevron{flex-shrink:0;color:var(--text3);margin-left:8px;transition:transform .2s;align-self:center;width:14px;height:14px;}
.cliff-chevron.open{transform:rotate(180deg);}
.cliff-body{padding:0 14px;max-height:0;overflow:hidden;transition:max-height .3s ease,padding .3s ease;}
.cliff-body.open{max-height:300px;padding:0 14px 12px;}
.cliff-note{font-size:12px;color:var(--text2);line-height:1.65;border-top:1px solid var(--border);padding-top:10px;}

/* ═══════════════════════════ ORG DIAGRAM ════════════════════════════ */
.org-section{background:var(--surface);border-radius:10px;border:1px solid var(--border);margin-bottom:14px;overflow:hidden;}
.org-header{padding:12px 19px 10px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.org-title{font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text2);}
.org-scroll{overflow-x:auto;padding:16px 19px;}
.org-tree{display:flex;flex-direction:column;gap:6px;min-width:500px;}
.org-root{background:var(--navy);color:#fff;border-radius:8px;padding:10px 16px;font-size:13px;font-weight:500;display:flex;align-items:center;gap:10px;margin-bottom:4px;}
.org-root-sub{font-size:11px;opacity:.7;}
.org-branches{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:6px;}
.org-unit{background:var(--bg);border:1px solid var(--border);border-radius:7px;padding:9px 12px;cursor:pointer;transition:all .12s;border-left:3px solid var(--blue);}
.org-unit:hover{background:#EBF0F9;border-left-color:var(--navy);}
.org-unit.expanded{background:#EBF0F9;border-left-color:var(--navy);}
.org-unit-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;}
.org-unit-num{font-size:9px;color:var(--text3);font-weight:600;flex-shrink:0;}
.org-unit-name{font-size:12px;font-weight:500;color:var(--text);line-height:1.3;}
.org-unit-amt{font-size:11px;font-weight:700;color:var(--navy);white-space:nowrap;margin-top:3px;}
.org-unit-konti{margin-top:6px;display:none;border-top:1px solid var(--border);padding-top:6px;}
.org-unit.expanded .org-unit-konti{display:block;}
.org-krow{font-size:10px;color:var(--text2);padding:2px 0;display:flex;gap:5px;align-items:baseline;}
.org-krow-n{color:var(--text3);flex-shrink:0;font-variant-numeric:tabular-nums;}
.org-krow-v{flex:1;line-height:1.3;}
.org-krow-b{font-weight:600;color:var(--navy);white-space:nowrap;}

/* ═══════════════════════════ AFTALER ════════════════════════════════ */
.aft-section{background:var(--surface);border-radius:10px;border:1px solid var(--border);margin-bottom:14px;overflow:hidden;}
.aft-header{padding:12px 19px 10px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.aft-title{font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text2);}
.aft-grid{padding:12px 19px;display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:8px;}
.aft-card{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px 12px;border-left:3px solid var(--teal);}
.aft-card-num{font-size:9px;color:var(--text3);font-weight:500;margin-bottom:3px;}
.aft-card-name{font-size:11px;font-weight:500;color:var(--text);line-height:1.4;margin-bottom:6px;}
.aft-card-meta{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:4px;}
.aft-card-amt{font-size:13px;font-weight:700;color:var(--teal);}
.aft-card-grp{font-size:9px;color:var(--text3);padding:1px 7px;background:rgba(28,54,100,.07);border-radius:10px;}
.aft-years{font-size:9px;color:var(--amber);font-weight:600;}
.aft-empty{padding:12px 19px;font-size:12px;color:var(--text3);font-style:italic;}

/* ═══════════════════════════ C. TEKSTANMÆRKNINGER ══════════════════ */
.ctekst-section{background:var(--surface);border-radius:10px;border:1px solid var(--border);margin-bottom:14px;overflow:hidden;}
.ctekst-topbar{padding:12px 19px 10px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.ctekst-title{font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text2);}
.ctekst-search{padding:9px 14px 7px;border-bottom:1px solid var(--border);}
.ctekst-search input{width:100%;padding:6px 11px;border:1px solid var(--border);border-radius:7px;font-size:12px;font-family:inherit;background:var(--bg);color:var(--text);outline:none;}
.ctekst-search input:focus{border-color:var(--navy2);}
.ctekst-cats{display:flex;gap:6px;padding:8px 14px;border-bottom:1px solid var(--border);flex-wrap:wrap;}
.ctekst-cat-btn{padding:3px 10px;border-radius:20px;font-size:11px;border:1px solid var(--border);background:transparent;color:var(--text2);cursor:pointer;font-family:inherit;transition:all .12s;}
.ctekst-cat-btn:hover{background:var(--bg);}
.ctekst-cat-btn.on{background:var(--navy);color:#fff;border-color:var(--navy);}
.ctekst-list{padding:0;}
.ctekst-item{border-bottom:1px solid var(--border);}
.ctekst-item:last-child{border-bottom:none;}
.ctekst-item-hdr{display:flex;align-items:flex-start;gap:10px;padding:10px 19px;cursor:pointer;transition:background .1s;}
.ctekst-item-hdr:hover{background:var(--bg);}
.ctekst-item-hdr.open{background:#EBF0F9;}
.ctekst-nr{font-size:11px;font-weight:700;color:var(--navy);min-width:32px;flex-shrink:0;padding-top:1px;}
.ctekst-cat-chip{font-size:9px;font-weight:600;padding:1px 7px;border-radius:10px;flex-shrink:0;white-space:nowrap;}
.ctekst-cat-chip.disp{background:#EBF0F9;color:#185FA5;}
.ctekst-cat-chip.mat{background:#E8F5EE;color:#1e6b45;}
.ctekst-konti{flex:1;min-width:0;}
.ctekst-kref{font-size:10px;color:var(--text3);line-height:1.6;word-break:break-all;}
.ctekst-body{display:none;padding:0 19px 12px 60px;}
.ctekst-body.open{display:block;}
.ctekst-text{font-size:12px;color:var(--text2);line-height:1.7;}
.ctekst-chev{color:var(--text3);flex-shrink:0;transition:transform .2s;width:12px;height:12px;margin-top:2px;}
.ctekst-chev.open{transform:rotate(180deg);}
.ctekst-empty{padding:12px 19px;font-size:12px;color:var(--text3);font-style:italic;}
.ctekst-foot{font-size:10px;color:var(--text3);padding:8px 19px;border-top:1px solid var(--border);background:var(--bg);}

/* INTRO */
.intro-section{background:linear-gradient(135deg,#EBF0F9 0%,#F0F4FB 100%);border:1px solid var(--border);border-radius:10px;padding:16px 19px;margin-bottom:14px;}
.intro-text{font-size:13px;color:var(--text2);line-height:1.75;}


.bgrp-section{background:var(--surface);border-radius:10px;border:1px solid var(--border);margin-bottom:14px;overflow:hidden;}
.bgrp-topbar{font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text2);padding:12px 19px 10px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.bgrp-search{padding:9px 14px 7px;border-bottom:1px solid var(--border);}
.bgrp-search input{width:100%;padding:6px 11px;border:1px solid var(--border);border-radius:7px;font-size:12px;font-family:inherit;background:var(--bg);color:var(--text);outline:none;}
.bgrp-item{border-bottom:1px solid var(--border);}
.bgrp-item:last-child{border-bottom:none;}
.bgrp-hdr{display:flex;align-items:center;gap:10px;padding:10px 19px;cursor:pointer;transition:background .12s;user-select:none;}
.bgrp-hdr:hover{background:var(--bg);}
.bgrp-hdr.open{background:#EBF0F9;}
.bgrp-grpnum{font-size:10px;font-weight:500;color:var(--text3);min-width:52px;flex-shrink:0;font-variant-numeric:tabular-nums;}
.bgrp-grpname{flex:1;font-size:13px;font-weight:500;color:var(--text);}
.bgrp-grpmeta{font-size:11px;color:var(--text3);text-align:right;flex-shrink:0;}
.bgrp-grpamt{font-size:13px;font-weight:700;color:var(--navy);margin-left:6px;white-space:nowrap;}
.bgrp-chev{color:var(--text3);flex-shrink:0;transition:transform .2s;width:13px;height:13px;margin-left:4px;}
.bgrp-chev.open{transform:rotate(180deg);}
.bgrp-body{display:none;border-top:1px solid rgba(28,54,100,.07);}
.bgrp-body.open{display:block;}
.krow{display:grid;grid-template-columns:88px 1fr auto auto;align-items:center;gap:8px;padding:6px 19px 6px 38px;border-bottom:1px solid rgba(28,54,100,.04);transition:background .08s;}
.krow:hover{background:rgba(75,127,196,.05);}
.krow:last-child{border-bottom:none;}
.krow-hidden{display:none;}
.knum{font-size:10px;color:var(--text3);font-variant-numeric:tabular-nums;font-weight:500;}
.knavn{font-size:12px;color:var(--text);line-height:1.4;}
.ktype{font-size:9px;font-weight:600;padding:1px 6px;border-radius:10px;white-space:nowrap;}
.ktype-D{background:#EBF0F9;color:#1C3664;}.ktype-L{background:#E8F5EE;color:#1e6b45;}.ktype-R{background:#FFF7E6;color:#854F0B;}.ktype-S{background:#F3F0FE;color:#534AB7;}.ktype-A{background:#FEF0EE;color:#993C1D;}.ktype-SE{background:#FEECF0;color:#993556;}
.kamt{font-size:12px;font-weight:700;color:var(--navy);white-space:nowrap;text-align:right;min-width:72px;}
.kamt-zero{font-size:11px;color:var(--text3);font-weight:400;}
.kamt-neg{font-size:12px;font-weight:600;color:#C0272D;}
.kanlæg{font-size:9px;color:var(--text3);display:block;text-align:right;}
.bgrp-foot{font-size:10px;color:var(--text3);padding:7px 19px;border-top:1px solid var(--border);background:var(--bg);}


/* ═══════════════════════ POLITISKE AFTALER ══════════════════════════ */
.paft-section {
  background: var(--surface);
  border-radius: 10px;
  border: 1px solid var(--border);
  margin-bottom: 14px;
  overflow: hidden;
}
.paft-topbar {
  padding: 13px 18px 11px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
}
.paft-topbar-left { display: flex; align-items: center; gap: 10px; }
.paft-icon {
  width: 32px; height: 32px; border-radius: 8px;
  background: linear-gradient(135deg, #1C3664, #2B5CA8);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.paft-headline { font-size: 13px; font-weight: 600; color: var(--text); }
.paft-sub { font-size: 11px; color: var(--text3); margin-top: 1px; }

/* Toolbar */
.paft-toolbar {
  padding: 8px 14px 7px;
  border-bottom: 1px solid var(--border);
  display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
}
.paft-search {
  flex: 1; min-width: 180px;
  padding: 5px 10px; border: 1px solid var(--border); border-radius: 7px;
  font-size: 12px; font-family: inherit; background: var(--bg);
  color: var(--text); outline: none; transition: border-color .15s;
}
.paft-search:focus { border-color: var(--navy2); }
.paft-filter-group { display: flex; gap: 4px; flex-wrap: wrap; }
.paft-chip {
  padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 500;
  border: 1px solid var(--border); background: transparent;
  color: var(--text2); cursor: pointer; font-family: inherit;
  transition: all .12s; white-space: nowrap;
}
.paft-chip:hover { background: var(--bg); }
.paft-chip.active { background: var(--navy); color: #fff; border-color: var(--navy); }

/* Grid */
.paft-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 10px;
  padding: 12px 14px;
}

/* Aftale-kort */
.paft-card {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 9px;
  overflow: hidden;
  cursor: pointer;
  transition: box-shadow .15s, border-color .15s;
  display: flex; flex-direction: column;
}
.paft-card:hover {
  border-color: var(--blue);
  box-shadow: 0 2px 10px rgba(28,54,100,.10);
}
.paft-card.open { border-color: var(--navy2); }
.paft-card-top {
  padding: 10px 12px 8px;
  border-left: 3px solid transparent;
}
.paft-card-top.type-Aftale        { border-left-color: #1C3664; }
.paft-card-top.type-Tillægsaftale { border-left-color: #C8A432; }
.paft-card-top.type-Delaftale     { border-left-color: #4E7FC4; }

.paft-type-row {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 5px;
}
.paft-type-badge {
  font-size: 9px; font-weight: 700; letter-spacing: .05em;
  text-transform: uppercase; padding: 2px 7px; border-radius: 10px;
}
.paft-type-badge.type-Aftale        { background: #EBF0F9; color: #1C3664; }
.paft-type-badge.type-Tillægsaftale { background: #FFF7E6; color: #854F0B; }
.paft-type-badge.type-Delaftale     { background: #EBF4FF; color: #1A5FAC; }
.paft-year {
  font-size: 11px; font-weight: 700; color: var(--text3);
  font-variant-numeric: tabular-nums;
}
.paft-subject {
  font-size: 12px; font-weight: 500; color: var(--text);
  line-height: 1.45; margin-bottom: 8px;
}

/* Parti-chips */
.paft-parties {
  display: flex; flex-wrap: wrap; gap: 3px;
}
.party-chip {
  font-size: 9px; font-weight: 700;
  padding: 2px 5px; border-radius: 4px;
  letter-spacing: .03em; line-height: 1.4;
}

/* Udvidet tekst */
.paft-card-body {
  display: none;
  padding: 8px 12px 10px;
  border-top: 1px solid var(--border);
  background: var(--surface);
}
.paft-card-body.open { display: block; }
.paft-full-text {
  font-size: 11px; color: var(--text2); line-height: 1.7;
}
.paft-month {
  font-size: 10px; color: var(--text3); margin-top: 6px;
  display: flex; align-items: center; gap: 5px;
}

/* Ingen resultater */
.paft-empty {
  padding: 16px 18px; font-size: 12px;
  color: var(--text3); font-style: italic; display: none;
}
.paft-foot {
  font-size: 10px; color: var(--text3);
  padding: 7px 18px;
  border-top: 1px solid var(--border);
  background: var(--bg);
  letter-spacing: .02em;
}

/* Source-note for §12 */
.paft-source-note {
  font-size: 10px; color: var(--text3);
  background: rgba(28,54,100,.04);
  border-left: 2px solid var(--blue);
  padding: 5px 10px; margin: 0 14px 10px;
  border-radius: 0 4px 4px 0;
}


/* ══════════════════════════ HIERARKISK ORG-DIAGRAM ══════════════════ */
.org2-section {
  background: var(--surface);
  border-radius: 10px;
  border: 1px solid var(--border);
  margin-bottom: 14px;
  overflow: hidden;
}
.org2-header {
  padding: 12px 18px 10px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
}
.org2-title { font-size: 10px; text-transform: uppercase; letter-spacing: .06em; color: var(--text2); }
.org2-wrap { padding: 16px 18px 14px; overflow-x: auto; }

/* Træ-layout */
.org2-tree { display: flex; flex-direction: column; gap: 0; min-width: 420px; }

/* Minister-niveau (top) */
.org2-root {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy2) 100%);
  color: #fff;
  border-radius: 9px;
  padding: 10px 16px;
  margin-bottom: 10px;
  display: flex; align-items: center; gap: 10px;
}
.org2-root-icon {
  width: 28px; height: 28px; border-radius: 7px;
  background: rgba(255,255,255,.15);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.org2-root-name { font-size: 13px; font-weight: 600; }
.org2-root-label { font-size: 10px; opacity: .7; margin-top: 1px; }

/* Departement-niveau */
.org2-dept {
  background: #EBF0F9;
  border: 1px solid rgba(28,54,100,.18);
  border-radius: 8px;
  padding: 9px 14px;
  margin-bottom: 8px;
  display: flex; align-items: center; gap: 9px;
  border-left: 4px solid var(--navy);
}
.org2-dept-label {
  font-size: 12px; font-weight: 600; color: var(--navy); flex: 1;
}
.org2-dept-desc { font-size: 11px; color: var(--text3); margin-top: 1px; }

/* Grid af styrelser */
.org2-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 7px;
  margin-top: 4px;
  position: relative;
  padding-left: 22px;
}
.org2-grid::before {
  content: '';
  position: absolute;
  left: 8px; top: 0; bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom, var(--border), transparent);
  border-radius: 2px;
}

/* Enhed-kort */
.org2-unit {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 9px 11px;
  cursor: pointer;
  transition: all .12s;
  border-left: 3px solid transparent;
  position: relative;
}
.org2-unit::before {
  content: '';
  position: absolute;
  left: -22px; top: 50%;
  width: 14px; height: 2px;
  background: var(--border);
}
.org2-unit:hover { border-left-color: var(--blue); box-shadow: 0 1px 6px rgba(28,54,100,.08); }
.org2-unit.open { border-left-color: var(--navy); background: #f5f8fd; }

/* Role-farver */
.org2-unit[data-role="dept"]    { border-left-color: var(--navy); background: #EBF0F9; }
.org2-unit[data-role="styrelse"]{ border-left-color: var(--blue); }
.org2-unit[data-role="myndighed"]{ border-left-color: var(--teal); }
.org2-unit[data-role="institution"]{ border-left-color: #9B7ED6; }
.org2-unit[data-role="uafh"]    { border-left-color: var(--gold); }
.org2-unit[data-role="stab"]    { border-left-color: #9AA3B7; }

.org2-unit-top { display: flex; align-items: flex-start; gap: 6px; }
.org2-unit-badge {
  font-size: 8px; font-weight: 700; padding: 1px 5px; border-radius: 8px;
  white-space: nowrap; flex-shrink: 0; margin-top: 1px;
}
.badge-dept        { background: #D5E0F3; color: #1C3664; }
.badge-styrelse    { background: #DDEEFF; color: #1A5FAC; }
.badge-myndighed   { background: #D8F5EC; color: #1D6B52; }
.badge-institution { background: #EDE8FA; color: #534AB7; }
.badge-uafh        { background: #FEF5D9; color: #7A5A00; }
.badge-stab        { background: #EBEBEB; color: #666; }

.org2-unit-name { font-size: 11.5px; font-weight: 500; color: var(--text); line-height: 1.35; flex: 1; }
.org2-unit-abbr { font-size: 9px; color: var(--text3); font-weight: 600; margin-top: 2px; }
.org2-unit-desc { display: none; font-size: 10.5px; color: var(--text3); line-height: 1.5; margin-top: 6px; border-top: 1px solid var(--border); padding-top: 5px; }
.org2-unit.open .org2-unit-desc { display: block; }

/* Underniveau (styrelsens interne enheder) */
.org2-children {
  margin-top: 6px; margin-left: 14px;
  display: none; border-left: 2px solid var(--border);
  padding-left: 8px;
}
.org2-unit.open .org2-children { display: block; }
.org2-child {
  font-size: 10px; color: var(--text2); padding: 3px 0;
  display: flex; align-items: center; gap: 5px;
}
.org2-child::before {
  content: '—'; color: var(--text3); flex-shrink: 0;
}

/* Forklaring */
.org2-legend {
  display: flex; gap: 10px; flex-wrap: wrap;
  padding: 8px 18px;
  border-top: 1px solid var(--border);
  background: var(--bg);
}
.org2-legend-item { display: flex; align-items: center; gap: 4px; font-size: 10px; color: var(--text3); }
.org2-legend-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }


/* Forlig-specifik styling */
.paft-card[data-forlig="1"] .paft-card-top {
  border-left-color: #C8A432;
}
.paft-type-badge.type-Forlig {
  background: #FEF5D9; color: #7A5A00;
}
.paft-forlig-star {
  font-size: 8px; color: #C8A432; font-weight: 700;
  letter-spacing: .04em; padding: 1px 5px;
  background: #FFFBEC; border: 1px solid #E8C84A;
  border-radius: 8px; margin-left: 4px;
  vertical-align: middle;
}
.paft-expires {
  font-size: 9px; color: var(--text3);
  padding: 1px 6px; background: rgba(28,54,100,.06);
  border-radius: 8px; white-space: nowrap;
}
.paft-expires.soon { color: #C0272D; background: #FEF0EE; }
.paft-filter-sep {
  width: 1px; height: 16px; background: var(--border);
  align-self: center; flex-shrink: 0;
}


/* ═══════════════════════ FLERÅRSBUDGET ═══════════════════════ */
.flbud-section {
  background: var(--surface);
  border-radius: 10px;
  border: 1px solid var(--border);
  margin-bottom: 14px;
  overflow: hidden;
}
.flbud-topbar {
  padding: 12px 18px 10px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
}
.flbud-title { font-size: 10px; text-transform: uppercase; letter-spacing: .06em; color: var(--text2); }
.flbud-toggle {
  display: flex; gap: 4px;
}
.flbud-toggle button {
  padding: 3px 9px; font-size: 10px; font-family: inherit;
  border: 1px solid var(--border); border-radius: 6px;
  background: transparent; color: var(--text2); cursor: pointer;
}
.flbud-toggle button.on { background: var(--navy); color: #fff; border-color: var(--navy); }
.flbud-body { padding: 12px 18px 10px; }
.flbud-label {
  font-size: 10px; text-transform: uppercase; letter-spacing: .05em;
  color: var(--text3); margin: 8px 0 6px;
}
.flbud-rows { display: flex; flex-direction: column; gap: 5px; }
.flbud-row {
  display: grid;
  grid-template-columns: 130px 1fr 70px;
  align-items: center; gap: 10px;
}
.flbud-grp-name {
  font-size: 11px; color: var(--text); white-space: nowrap;
  overflow: hidden; text-overflow: ellipsis;
}
.flbud-bars { display: flex; gap: 2px; align-items: flex-end; height: 28px; }
.flbud-bar-wrap {
  display: flex; flex-direction: column; align-items: center;
  flex: 1; height: 28px; justify-content: flex-end;
  position: relative;
}
.flbud-bar {
  width: 100%; border-radius: 2px 2px 0 0;
  transition: opacity .15s;
  min-height: 2px;
}
.flbud-bar:hover { opacity: .8; }
.flbud-bar.year-cur { background: var(--navy2); }
.flbud-bar.year-past { background: rgba(28,54,100,.25); }
.flbud-bar.year-future { background: rgba(28,54,100,.45); }
.flbud-year-lbl {
  font-size: 8px; color: var(--text3); margin-top: 2px;
  text-align: center; line-height: 1;
}
.flbud-cur-lbl {
  font-size: 8px; font-weight: 700; color: var(--navy2);
  margin-top: 2px; text-align: center;
}
.flbud-val {
  font-size: 11px; font-weight: 600; color: var(--navy);
  text-align: right; white-space: nowrap;
}
.flbud-nettotal {
  background: rgba(28,54,100,.04); border-radius: 6px;
  padding: 7px 10px; margin-bottom: 8px;
  display: flex; align-items: center; gap: 10px;
}
.flbud-nt-label { font-size: 11px; font-weight: 600; color: var(--text); flex: 1; }
.flbud-nt-bars { flex: 2; display: flex; gap: 2px; align-items: flex-end; height: 24px; }
.flbud-nt-bar {
  flex: 1; border-radius: 2px 2px 0 0; min-height: 2px;
}
.flbud-nt-bar.year-cur { background: var(--navy); }
.flbud-nt-bar.year-past { background: rgba(28,54,100,.22); }
.flbud-nt-bar.year-future { background: rgba(28,54,100,.5); }
.flbud-nt-val { font-size: 12px; font-weight: 700; color: var(--navy); white-space: nowrap; }
.flbud-foot {
  font-size: 10px; color: var(--text3); padding: 7px 18px;
  border-top: 1px solid var(--border); background: var(--bg);
}
.flbud-yaxis {
  display: flex; gap: 2px;
}
.flbud-yaxis-lbl {
  flex: 1; font-size: 7px; color: var(--text3);
  text-align: center; margin-top: 1px;
}

/* ═════════════════════ GENERELLE OPLYSNINGER ════════════════ */
.genop-section {
  background: var(--surface);
  border-radius: 10px;
  border: 1px solid var(--border);
  margin-bottom: 14px;
  overflow: hidden;
}
.genop-topbar {
  padding: 12px 18px 10px;
  border-bottom: 1px solid var(--border);
  font-size: 10px; text-transform: uppercase; letter-spacing: .06em; color: var(--text2);
}
.genop-item { border-bottom: 1px solid var(--border); }
.genop-item:last-child { border-bottom: none; }
.genop-hdr {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 18px; cursor: pointer;
  transition: background .1s; user-select: none;
}
.genop-hdr:hover { background: var(--bg); }
.genop-hdr.open { background: #EBF0F9; }
.genop-icon {
  width: 20px; height: 20px; border-radius: 5px;
  background: var(--bg); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; flex-shrink: 0; color: var(--text3);
}
.genop-name { flex: 1; font-size: 12px; font-weight: 500; color: var(--text); }
.genop-chev { color: var(--text3); transition: transform .2s; width: 12px; height: 12px; }
.genop-chev.open { transform: rotate(180deg); }
.genop-body { display: none; padding: 10px 18px 12px 48px; }
.genop-body.open { display: block; }
.genop-text { font-size: 12px; color: var(--text2); line-height: 1.75; }
.genop-foot {
  font-size: 10px; color: var(--text3); padding: 7px 18px;
  border-top: 1px solid var(--border); background: var(--bg);
}


/* ═══════════════════════ STICKY TABS ════════════════════════ */
.detail-tabs {
  position: sticky;
  top: 0;
  z-index: 50;
  background: var(--surface);
  border-bottom: 2px solid var(--border);
  display: flex;
  gap: 0;
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
  box-shadow: 0 2px 8px rgba(0,0,0,.07);
  margin: 0 -20px 16px;
  padding: 0 20px;
}
.detail-tabs::-webkit-scrollbar { display: none; }
.dtab {
  padding: 9px 14px 8px;
  font-size: 11px; font-weight: 500; font-family: inherit;
  color: var(--text2); border: none; background: transparent;
  cursor: pointer; white-space: nowrap;
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  transition: color .12s, border-color .12s;
}
.dtab:hover { color: var(--navy); }
.dtab.on { color: var(--navy); border-bottom-color: var(--navy2); font-weight: 600; }

/* ════════════════════ GLOBAL SØGNING ════════════════════════ */
.global-search-wrap {
  position: relative; margin-bottom: 16px;
}
.global-search-input {
  width: 100%; padding: 10px 16px 10px 38px;
  border: 1.5px solid var(--border); border-radius: 9px;
  font-size: 13px; font-family: inherit;
  background: var(--surface); color: var(--text);
  outline: none; transition: border-color .15s;
  box-sizing: border-box;
}
.global-search-input:focus { border-color: var(--navy2); }
.global-search-icon {
  position: absolute; left: 12px; top: 50%;
  transform: translateY(-50%); color: var(--text3);
  pointer-events: none; width: 16px; height: 16px;
}
.global-search-results {
  display: none;
  position: absolute; top: calc(100% + 4px); left: 0; right: 0;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 9px; box-shadow: 0 4px 20px rgba(0,0,0,.12);
  z-index: 100; max-height: 400px; overflow-y: auto;
}
.gsr-item {
  padding: 9px 14px; border-bottom: 1px solid var(--border);
  cursor: pointer; transition: background .08s;
}
.gsr-item:last-child { border-bottom: none; }
.gsr-item:hover { background: var(--bg); }
.gsr-ministry { font-size: 10px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: .05em; }
.gsr-title { font-size: 12px; color: var(--text); margin-top: 1px; }
.gsr-amount { font-size: 11px; font-weight: 600; color: var(--navy); float: right; }
.gsr-type { font-size: 9px; color: var(--text3); margin-top: 1px; }
.gsr-empty { padding: 14px; font-size: 12px; color: var(--text3); text-align: center; font-style: italic; }
.gsr-section-label { padding: 6px 14px 3px; font-size: 9px; font-weight: 700; color: var(--text3); text-transform: uppercase; letter-spacing: .06em; background: var(--bg); border-bottom: 1px solid var(--border); }

/* Simplificeret flerårsbudget - 3 punkter */
.flbud3-wrap {
  display: flex; flex-direction: column; gap: 6px;
  padding: 10px 18px 8px;
}
.flbud3-row {
  display: grid;
  grid-template-columns: 130px 1fr auto;
  align-items: center; gap: 12px;
}
.flbud3-name {
  font-size: 11px; color: var(--text);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.flbud3-track {
  height: 8px; background: rgba(28,54,100,.08); border-radius: 4px;
  position: relative; overflow: visible;
}
.flbud3-dot {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 8px; height: 8px; border-radius: 50%; border: 2px solid #fff;
  box-shadow: 0 0 0 1px currentColor;
}
.flbud3-line {
  position: absolute; height: 3px; top: 50%; transform: translateY(-50%);
  border-radius: 2px; background: linear-gradient(90deg, rgba(28,54,100,.2), var(--navy2));
}
.flbud3-dot.d2023 { background: rgba(28,54,100,.3); color: rgba(28,54,100,.3); left: 0; }
.flbud3-dot.d2026 { background: var(--navy2); color: var(--navy2); }
.flbud3-dot.d2029 { background: rgba(28,54,100,.6); color: rgba(28,54,100,.6); right: 0; }
.flbud3-legend {
  display: flex; justify-content: space-between; padding: 0 0 4px;
  font-size: 9px; color: var(--text3);
}
.flbud3-legend span.cur { font-weight: 700; color: var(--navy2); }
.flbud3-val { font-size: 11px; font-weight: 700; color: var(--navy); white-space: nowrap; text-align: right; }
.flbud3-arrow {
  font-size: 10px; margin-left: 4px;
}
.flbud3-arrow.up { color: #C0272D; }
.flbud3-arrow.down { color: #1D9E75; }
.flbud3-toggle { display: flex; gap: 4px; }
.flbud3-toggle button {
  padding: 3px 9px; font-size: 10px; font-family: inherit;
  border: 1px solid var(--border); border-radius: 6px;
  background: transparent; color: var(--text2); cursor: pointer;
}
.flbud3-toggle button.on { background: var(--navy); color: #fff; border-color: var(--navy); }

/* C. Tekstanmærkninger — vis-alle knap */
.ctekst-showmore {
  padding: 10px 19px;
  border-top: 1px solid var(--border);
  text-align: center;
}
.ctekst-showmore button {
  padding: 5px 16px; font-size: 11px; font-family: inherit;
  border: 1px solid var(--border); border-radius: 7px;
  background: var(--bg); color: var(--text2); cursor: pointer;
  transition: all .12s;
}
.ctekst-showmore button:hover { background: var(--navy); color: #fff; border-color: var(--navy); }

/* Kontolinjer: grup-niveau-default */
.bgrp-summary {
  padding: 8px 19px 8px 35px;
  font-size: 11px; color: var(--text3); font-style: italic;
}


.ctekst-item.ct-hidden { display: none !important; }

/* Klikbar-indikator på ministry-kort */
.min-card {
  cursor: pointer;
  position: relative;
}
.min-card::after {
  content: 'Se detaljer →';
  position: absolute;
  bottom: 10px; right: 12px;
  font-size: 10px; font-weight: 600;
  color: var(--navy2);
  opacity: 0;
  transition: opacity .15s;
  pointer-events: none;
}
.min-card:hover::after {
  opacity: 1;
}
.min-card:hover {
  box-shadow: 0 4px 20px rgba(28,54,100,.15);
  transform: translateY(-1px);
}

/* Onboarding-banner */
.onboarding-banner {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy2) 100%);
  color: #fff;
  border-radius: 10px;
  padding: 14px 20px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 14px;
  font-size: 12px;
  line-height: 1.5;
  position: relative;
}
.onboarding-banner strong { font-weight: 700; }
.onboarding-banner .ob-icon {
  font-size: 24px; flex-shrink: 0;
}
.onboarding-banner .ob-close {
  position: absolute; top: 8px; right: 10px;
  background: rgba(255,255,255,.2); border: none;
  color: #fff; border-radius: 50%;
  width: 20px; height: 20px; cursor: pointer;
  font-size: 12px; line-height: 20px;
  text-align: center; padding: 0;
}
.onboarding-banner .ob-close:hover {
  background: rgba(255,255,255,.35);
}

/* Pulserende ring på første 3 kort ved første load */
@keyframes pulse-ring {
  0%   { box-shadow: 0 0 0 0 rgba(78,127,196,.4); }
  70%  { box-shadow: 0 0 0 8px rgba(78,127,196,0); }
  100% { box-shadow: 0 0 0 0 rgba(78,127,196,0); }
}
.min-card.pulse-hint {
  animation: pulse-ring 2s ease-out 2;
}

/* Chevron-ikon i kortet */
.min-card-chevron {
  position: absolute;
  top: 50%; right: 14px;
  transform: translateY(-50%);
  color: var(--text3);
  opacity: 0;
  transition: opacity .15s, right .12s;
}
.min-card:hover .min-card-chevron {
  opacity: 1; right: 10px;
}


/* ══════════════════ FLERÅRSBUDGET — TBL ══════════════════════ */
.flbud-section {
  background: var(--surface);
  border-radius: 10px;
  border: 1px solid var(--border);
  margin-bottom: 14px;
  overflow: hidden;
}
.flbud-topbar {
  padding: 12px 18px 10px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 8px;
}
.flbud-title { font-size: 10px; text-transform: uppercase; letter-spacing: .06em; color: var(--text2); }
.flbud3-toggle { display: flex; gap: 4px; }
.flbud3-toggle button {
  padding: 3px 10px; font-size: 10px; font-family: inherit;
  border: 1px solid var(--border); border-radius: 6px;
  background: transparent; color: var(--text2); cursor: pointer;
}
.flbud3-toggle button.on { background: var(--navy); color: #fff; border-color: var(--navy); }

/* Tabellen */
.flbud-tbl {
  width: 100%; border-collapse: collapse; font-size: 12px;
}
.flbud-tbl th {
  padding: 7px 12px 6px;
  text-align: right; font-size: 10px; font-weight: 600;
  color: var(--text3); text-transform: uppercase; letter-spacing: .04em;
  border-bottom: 2px solid var(--border); white-space: nowrap;
}
.flbud-tbl th:first-child { text-align: left; }
.flbud-tbl th.cur { color: var(--navy2); }

.flbud-tbl td {
  padding: 7px 12px;
  border-bottom: 1px solid rgba(28,54,100,.06);
  vertical-align: middle;
}
.flbud-tbl tr:last-child td { border-bottom: none; }
.flbud-tbl tr:hover td { background: var(--bg); }

.flbud-tbl td.name {
  font-size: 12px; color: var(--text); max-width: 200px;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.flbud-tbl td.amt {
  text-align: right; font-variant-numeric: tabular-nums;
  color: var(--text2); white-space: nowrap;
}
.flbud-tbl td.amt.cur {
  font-weight: 700; color: var(--navy);
}
.flbud-tbl td.trend {
  text-align: right; white-space: nowrap; width: 60px;
}
.flbud-trend-up   { color: #C0272D; font-size: 11px; font-weight: 600; }
.flbud-trend-down { color: #1D9E75; font-size: 11px; font-weight: 600; }
.flbud-trend-flat { color: var(--text3); font-size: 11px; }

/* Total-rækken */
.flbud-tbl tr.flbud-total td {
  background: rgba(28,54,100,.04);
  font-weight: 700; border-bottom: 2px solid var(--border);
}
.flbud-tbl tr.flbud-total td.name { color: var(--navy); }


.flbud-foot {
  font-size: 10px; color: var(--text3); padding: 7px 12px;
  border-top: 1px solid var(--border); background: var(--bg);
}

</style>
