const ROLE_LABEL = {
  dept:'Departement', styrelse:'Styrelse', myndighed:'Myndighed',
  institution:'Institution', uafh:'Uafhængig', stab:'Enhed/stab'
};
const ROLE_BADGE = {
  dept:'badge-dept', styrelse:'badge-styrelse', myndighed:'badge-myndighed',
  institution:'badge-institution', uafh:'badge-uafh', stab:'badge-stab'
};

function renderOrg(ministerId) {
  const prefix = String(ministerId).padStart(2,'0');
  const od = ORG_DATA[prefix];
  if (!od) return '';

  // Tæl enheder
  const totalUnits = od.children.length;
  const nonDept = od.children.filter(c=>c.role!=='dept');

  // Departementet
  const dept = od.children.find(c=>c.role==='dept');
  const deptHTML = dept ? `
    <div class="org2-dept">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <rect x="1" y="1" width="12" height="12" rx="2" stroke="var(--navy)" stroke-width="1.3"/>
        <path d="M4 7h6M7 4v6" stroke="var(--navy)" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
      <div>
        <div class="org2-dept-label">${dept.name}</div>
        ${dept.desc ? `<div class="org2-dept-desc">${dept.desc}</div>` : ''}
      </div>
    </div>` : '';

  // Øvrige enheder
  const unitsHTML = od.children.filter(c=>c.role!=='dept').map((unit, i) => {
    const badge = ROLE_BADGE[unit.role] || 'badge-stab';
    const roleLabel = ROLE_LABEL[unit.role] || unit.role;
    const abbrSpan = unit.abbr ? `<div class="org2-unit-abbr">${unit.abbr}</div>` : '';
    const descDiv = unit.desc ? `<div class="org2-unit-desc">${unit.desc}</div>` : '';
    
    // Underenheder
    const subUnits = (unit.children||[]).map(sub =>
      `<div class="org2-child">${sub.name}</div>`
    ).join('');
    const childrenDiv = subUnits ? `<div class="org2-children">${subUnits}</div>` : '';
    
    const hasExpand = unit.desc || subUnits;
    
    return `<div class="org2-unit" data-role="${unit.role}"
        ${hasExpand ? `onclick="toggleOrg2Unit(this)"` : ''}>
      <div class="org2-unit-top">
        <span class="org2-unit-badge ${badge}">${roleLabel}</span>
        <div class="org2-unit-name">${unit.name}</div>
      </div>
      ${abbrSpan}
      ${descDiv}
      ${childrenDiv}
    </div>`;
  }).join('');

  const legend = `
    <div class="org2-legend">
      <span class="org2-legend-item"><span class="org2-legend-dot" style="background:#3d6db5"></span>Styrelse</span>
      <span class="org2-legend-item"><span class="org2-legend-dot" style="background:#1D9E75"></span>Myndighed</span>
      <span class="org2-legend-item"><span class="org2-legend-dot" style="background:#9B7ED6"></span>Institution</span>
      <span class="org2-legend-item"><span class="org2-legend-dot" style="background:#C8A432"></span>Uafhængig</span>
      <span class="org2-legend-item"><span class="org2-legend-dot" style="background:#9AA3B7"></span>Enhed/stab</span>
      <span style="font-size:10px;color:var(--text3);margin-left:auto">Klik på enhed for beskrivelse · Kilde: Ministeriernes hjemmesider 2025</span>
    </div>`;

  return `
  <div class="org2-section">
    <div class="org2-header">
      <span class="org2-title">Organisationsstruktur · ${totalUnits} enheder</span>
      <span style="font-size:11px;color:var(--text3)">${nonDept.length} styrelser og institutioner</span>
    </div>
    <div class="org2-wrap">
      <div class="org2-tree">
        <div class="org2-root">
          <div class="org2-root-icon">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M7 1L13 5v8H1V5L7 1z" stroke="white" stroke-width="1.2" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <div class="org2-root-name">§ ${ministerId} · ${od.name}</div>
            <div class="org2-root-label">Ministerområde</div>
          </div>
        </div>
        ${deptHTML}
        <div class="org2-grid">${unitsHTML}</div>
      </div>
    </div>
    ${legend}
  </div>`;
}

function toggleOrg2Unit(el) {
  el.classList.toggle('open');
}



