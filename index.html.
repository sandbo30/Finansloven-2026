function toggleCliff(minId, idx) {
  const body    = document.getElementById(`cliff-body-${minId}-${idx}`);
  const chevron = body?.previousElementSibling?.querySelector('.cliff-chevron');
  if (!body) return;
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open', !isOpen);
  chevron?.classList.toggle('open', !isOpen);
}


function renderBevGroups(ministerId) {
  const prefix = String(ministerId).padStart(2,'0');
  const d = BEV_DATA[prefix];
  if (!d || !d.grp_order || !d.grp_order.length) return '';
  const totalKonti = d.grp_order.reduce((s,g)=>s+d.groups[g].konti.length,0);
  const grandTotal = d.grp_order.reduce((s,g)=>s+d.groups[g].konti.reduce((ss,k)=>ss+(k.b||0),0),0);
  const grpHTML = d.grp_order.map((grpKey,idx) => {
    const gd = d.groups[grpKey];
    const grpTotal = gd.konti.reduce((s,k)=>s+(k.b||0),0);
    const hasPos = gd.konti.some(k=>k.b>0);
    const rows = gd.konti.map(k => {
      let amtHTML;
      if(k.b===null) amtHTML='<span class="kamt kamt-zero">—</span>';
      else if(k.b<0) amtHTML=`<span class="kamt kamt-neg">${fmtB(k.b)}</span>`;
      else if(k.b===0) amtHTML='<span class="kamt kamt-zero">0 kr.</span>';
      else amtHTML=`<span class="kamt">${fmtB(k.b)}</span>`;
      const anlæg=(k.b2&&k.b2>0)?`<span class="kanlæg">+${fmtB(k.b2,true)} anlæg</span>`:'';
      const typeBadge=k.t?`<span class="ktype ktype-${k.t}">${BTYPE_LBL[k.t]||k.t}</span>`:'<span></span>';
      return `<div class="krow" data-s="${(k.n+' '+k.v).toLowerCase()}">
        <span class="knum">${k.n}</span><span class="knavn">${k.v}</span>
        ${typeBadge}<span style="text-align:right">${amtHTML}${anlæg}</span></div>`;
    }).join('');
    const amtSpan=hasPos?`<span class="bgrp-grpamt">${fmtB(grpTotal,true)}</span>`:`<span style="font-size:11px;color:var(--text3);margin-left:6px">${grpTotal===0?'0 kr.':''}</span>`;
    return `<div class="bgrp-item" id="bgi-${prefix}-${idx}">
      <div class="bgrp-hdr" onclick="toggleBgrp('${prefix}',${idx})">
        <span class="bgrp-grpnum">${grpKey}</span>
        <span class="bgrp-grpname">${gd.name}</span>
        <span class="bgrp-grpmeta">${gd.konti.length} konti${amtSpan}</span>
        <svg class="bgrp-chev" id="bgchev-${prefix}-${idx}" viewBox="0 0 13 13" fill="none">
          <path d="M2.5 4.5L6.5 8.5L10.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </div>
      <div class="bgrp-body" id="bgbody-${prefix}-${idx}">${rows}</div></div>`;
  }).join('');
  return `<div class="bgrp-section" id="sec-bev-${prefix}">
    <div class="bgrp-topbar">
      <span>Konti og formål · ${d.grp_order.length} grupper · ${totalKonti} kontolinjer</span>
      <span style="font-size:12px;font-weight:700;color:var(--navy)">Udgifter i alt: ${fmtB(grandTotal)}</span>
    </div>
    <div class="bgrp-search"><input type="text" placeholder="Søg i kontolinjer…" oninput="filterBgrp('${prefix}',this.value)"></div>
    <div id="bglist-${prefix}">${grpHTML}</div>
    <div class="bgrp-foot">Kilde: Finanslov 2026, B. Bevillinger · D=Driftsbev. · L=Lovbunden · R=Reservationsbev. · S=Statsvirksomhed · A=Anlægsbev.</div>
  </div>`;
}
function toggleBgrp(prefix,idx){const body=document.getElementById(`bgbody-${prefix}-${idx}`);const hdr=document.getElementById(`bgi-${prefix}-${idx}`).querySelector('.bgrp-hdr');const chev=document.getElementById(`bgchev-${prefix}-${idx}`);if(!body)return;const open=body.classList.toggle('open');hdr.classList.toggle('open',open);chev.classList.toggle('open',open);}
function filterBgrp(prefix,query){const q=query.toLowerCase().trim();const list=document.getElementById(`bglist-${prefix}`);if(!list)return;let any=false;list.querySelectorAll('.bgrp-item').forEach((item,idx)=>{const gn=(item.querySelector('.bgrp-grpname')?.textContent||'').toLowerCase();const gk=(item.querySelector('.bgrp-grpnum')?.textContent||'').toLowerCase();const gm=!q||gn.includes(q)||gk.includes(q);const rows=item.querySelectorAll('.krow');let iv=false;if(gm){rows.forEach(r=>r.classList.remove('krow-hidden'));iv=true;}else{rows.forEach(r=>{const s=r.dataset.s||'';const show=s.includes(q);r.classList.toggle('krow-hidden',!show);if(show)iv=true;});}item.style.display=iv?'':'none';any=any||iv;if(q&&iv){const body=document.getElementById(`bgbody-${prefix}-${idx}`);const hdr=item.querySelector('.bgrp-hdr');const chev=item.querySelector('.bgrp-chev');if(body&&!body.classList.contains('open')){body.classList.add('open');hdr?.classList.add('open');chev?.classList.add('open');}}else if(!q){const body=document.getElementById(`bgbody-${prefix}-${idx}`);const hdr=item.querySelector('.bgrp-hdr');const chev=item.querySelector('.bgrp-chev');body?.classList.remove('open');hdr?.classList.remove('open');chev?.classList.remove('open');}});} 

