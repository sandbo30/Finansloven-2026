let gsrTimeout = null;
let gsrOpen = false;

function initGlobalSearch() {
  const inp = document.getElementById('global-search');
  if (!inp) return;
  inp.addEventListener('input', e => {
    clearTimeout(gsrTimeout);
    gsrTimeout = setTimeout(() => globalSearch(e.target.value), 180);
  });
  inp.addEventListener('focus', () => {
    if (inp.value.trim()) globalSearch(inp.value);
  });
  document.addEventListener('click', e => {
    if (!e.target.closest('.global-search-wrap')) closeGSR();
  });
  inp.addEventListener('keydown', e => {
    if (e.key === 'Escape') { closeGSR(); inp.blur(); }
  });
}

function globalSearch(q) {
  const box = document.getElementById('gsr-box');
  if (!box) return;
  q = q.trim().toLowerCase();
  if (q.length < 2) { closeGSR(); return; }

  const hits = SEARCH_IDX.filter(s =>
    s.t.toLowerCase().includes(q) ||
    s.mn.toLowerCase().includes(q) ||
    s.n.toLowerCase().includes(q)
  ).slice(0, 30);

  if (!hits.length) {
    box.innerHTML = '<div class="gsr-empty">Ingen resultater</div>';
  } else {
    // Gruppér
    const byType = {};
    hits.forEach(h => { (byType[h.cat] = byType[h.cat]||[]).push(h); });

    let html = '';
    if (byType.forlig?.length) {
      html += '<div class="gsr-section-label">Politiske forlig</div>';
      html += byType.forlig.map(h => `
        <div class="gsr-item" onclick="gsrGoTo('${h.p}')">
          <div class="gsr-ministry">§ ${parseInt(h.p)} · ${h.mn}</div>
          <div class="gsr-title">
            <span class="gsr-amount" style="margin-left:8px">${h.n}</span>
            ${h.t}
          </div>
        </div>`).join('');
    }
    if (byType.konto?.length) {
      html += '<div class="gsr-section-label">Kontolinjer</div>';
      html += byType.konto.slice(0,20).map(h => `
        <div class="gsr-item" onclick="gsrGoTo('${h.p}')">
          <div class="gsr-ministry">§ ${parseInt(h.p)} · ${h.mn}</div>
          <div class="gsr-title">
            <span class="gsr-amount">${h.b != null ? fmtB(h.b) : ''}</span>
            <span style="font-size:10px;color:var(--text3);margin-right:6px">${h.n}</span>
            ${h.t}
          </div>
        </div>`).join('');
    }
    box.innerHTML = html;
  }
  box.style.display = 'block';
  gsrOpen = true;
}

function closeGSR() {
  const box = document.getElementById('gsr-box');
  if (box) box.style.display = 'none';
  gsrOpen = false;
}

function gsrGoTo(prefix) {
  closeGSR();
  document.getElementById('global-search').value = '';
  // Find og åbn ministeriet
  const ministerId = parseInt(prefix);
  const card = document.querySelector(`[data-id="${ministerId}"]`);
  if (card) {
    card.click();
    setTimeout(() => {
      const detail = document.getElementById('detail-panel');
      if (detail) detail.scrollIntoView({behavior:'smooth', block:'start'});
    }, 150);
  }
