function fmtBs(v) {
  if (v == null) return '—';
  if (v === 0)   return '0,0 mia.';
  const b = v / 1000;
  const decimals = Math.abs(b) >= 10 ? 1 : Math.abs(b) >= 1 ? 1 : 2;
  return b.toFixed(decimals).replace('.', ',') + ' mia.';
}

// ── FLERÅRSBUDGET ────────────────────────────────────────────────
const flbudMode = {};   // prefix → 'under' | 'uden'

function renderFlbud(ministerId) {
  const prefix = String(ministerId).padStart(2,'0');
  const fd = FLBUD_DATA[prefix];
  if (!fd) return '';

  const years = fd.years || [2023,2024,2025,2026,2027,2028,2029];
  const i23 = years.indexOf(2023);
  const i26 = years.indexOf(2026);
  const i29 = years.indexOf(2029) >= 0 ? years.indexOf(2029) : years.length - 1;

  if (!flbudMode[prefix]) flbudMode[prefix] = fd.under_loft?.nettotal ? 'under' : 'uden';

  function fmtTbl(v) {
    if (v == null) return '<span style="color:var(--text3)">—</span>';
    if (v === 0)   return '0,0 mia.';
    const b = v / 1000;
    const decimals = Math.abs(b) >= 10 ? 1 : Math.abs(b) >= 1 ? 1 : 2;
    return b.toFixed(decimals).replace('.', ',') + ' mia.';
  }

  function pctArrow(vFrom, vTo) {
    if (vFrom == null || vTo == null || vFrom === 0) return '';
    const pct = (vTo - vFrom) / Math.abs(vFrom) * 100;
    if (Math.abs(pct) < 3) return '<span class="flbud-trend-flat">→</span>';
    const cap = Math.abs(pct) > 999 ? '>999' : Math.abs(Math.round(pct)).toString();
    return pct > 0
      ? `<span class="flbud-trend-up">↑${cap}%</span>`
      : `<span class="flbud-trend-down">↓${cap}%</span>`;
  }

  function renderSect(sect) {
    const d = fd[sect];
    if (!d) return '';
    const nt  = d.nettotal;
    const grps = d.grupper || {};
    if (!nt && !Object.keys(grps).length) return '';

    // Find max F2026-beløb for mini-bar

    function row(name, vals, isTot) {
      const v23 = vals?.[i23] ?? null;
      const v26 = vals?.[i26] ?? null;
      const v29 = vals?.[i29] ?? null;
      return `<tr class="${isTot ? 'flbud-total' : ''}">
        <td class="name" title="${name}">${name}</td>
        <td class="amt">${fmtTbl(v23)}</td>
        <td class="amt cur">${fmtTbl(v26)}</td>
        <td class="amt">${fmtTbl(v29)}</td>
        <td class="trend">${pctArrow(v23, v26)}</td>
      </tr>`;
    }

    const totalRow = nt ? row('Nettotal', nt, true) : '';
    const grpRows  = Object.entries(grps).map(([g, gd]) => row(gd.name || g, gd.vals, false)).join('');

    return `
    <table class="flbud-tbl">
      <thead><tr>
        <th>Gruppe</th>
        <th>2023 (R)</th>
        <th class="cur">F2026</th>
        <th>BO2029</th>
        <th>Ændring</th>
      </tr></thead>
      <tbody>${totalRow}${grpRows}</tbody>
    </table>`;
  }

  const hasUnder = !!(fd.under_loft?.nettotal || Object.keys(fd.under_loft?.grupper||{}).length);
  const hasUden  = !!(fd.uden_loft?.nettotal  || Object.keys(fd.uden_loft?.grupper||{}).length);
  const mode = flbudMode[prefix];

  const toggleHTML = (hasUnder && hasUden) ? `
    <div class="flbud3-toggle">
      <button class="${mode==='under'?'on':''}" onclick="setFlbudMode('${prefix}','under')">Under driftsloft</button>
      <button class="${mode==='uden'?'on':''}"  onclick="setFlbudMode('${prefix}','uden')">Anlæg og reserver</button>
    </div>` : '';

  const sectHTML = renderSect(mode === 'under' ? 'under_loft' : 'uden_loft');

  return `
  <div class="flbud-section" id="sec-flbud-${prefix}">
    <div class="flbud-topbar">
      <span class="flbud-title">Flerårsbudget · mia. kr. · Ændring = 2023 → F2026</span>
      <div id="flbud-toggle-${prefix}">${toggleHTML}</div>
    </div>
    ${sectHTML}
    <div class="flbud-foot">
      Alle beløb i mia. kr. · R = regnskab (realiseret) · F2026 = Finanslov 2026 (bevilling) · BO2027–2029 = budgetoverslagsår under forudsat uændret politik — ikke vedtagne beløb · Kilde: FL2026, Anmærkninger
    </div>
  </div>`;
}

function setFlbudMode(prefix, mode) {
  flbudMode[prefix] = mode;
  const el = document.getElementById('sec-flbud-' + prefix);
  if (!el) return;
  el.outerHTML = renderFlbud(parseInt(prefix));
}

// ── GENERELLE OPLYSNINGER ────────────────────────────────────────
function renderGenOpl(ministerId) {
  const prefix = String(ministerId).padStart(2,'0');
  const ad = ANM_DATA[prefix];
  const genOpl = ad?.gen_opl;
  if (!genOpl || !genOpl.length) return '';

  // Filtrer trivielle afsnit ud
  const SKIP = /^(Merværdiafgift|Udlån.udleje|Rebudgettering|Produktansvar|Udgifter til anskaffelse)/i;
  const relevant = genOpl.filter(b => !SKIP.test(b.title) && b.text && b.text.length > 80);
  if (!relevant.length) return '';

  const items = relevant.map((b, idx) => {
    const ICONS = {'Anskaffelse':'✈','Flyvninger':'✈','Transport':'🚗',
      'Bistand':'🛡️','Valutakurs':'💱','Udgifter til k':'👑','Indtægt':'📥'};
    const icon = Object.entries(ICONS).find(([k]) => b.title.startsWith(k))?.[1] || '📄';
    return `<div class="genop-item">
      <div class="genop-hdr" onclick="toggleGenOpl(this)">
        <div class="genop-icon">${icon}</div>
        <span class="genop-name">${b.title}</span>
        <svg class="genop-chev" viewBox="0 0 12 12" fill="none">
          <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="genop-body">
        <p class="genop-text">${b.text}</p>
      </div>
    </div>`;
  }).join('');

  return `
  <div class="genop-section">
    <div class="genop-topbar">Generelle oplysninger · ${relevant.length} afsnit</div>
    ${items}
    <div class="genop-foot">Kilde: Finanslov 2026, § ${ministerId}, Anmærkninger – Generelle oplysninger</div>
  </div>`;
}

function toggleGenOpl(hdr) {
  const body = hdr.nextElementSibling;
  const chev = hdr.querySelector('.genop-chev');
  if (!body) return;
  const open = body.classList.toggle('open');
  hdr.classList.toggle('open', open);
  chev?.classList.toggle('open', open);
}


