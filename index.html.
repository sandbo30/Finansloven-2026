          Åbn browserens konsol (F12 → Console) for at se den præcise fejlmeddelelse.<br><br>
          <code style="font-size:12px;background:#F0F4FB;padding:4px 8px;border-radius:4px;">${err.message}</code>
        </div>
      </div>`;
  }
}
</script>
<script>document.addEventListener("DOMContentLoaded", initGlobalSearch);</script>
<script>
// Onboarding: vis ikke hvis allerede set
if (typeof localStorage !== 'undefined' && localStorage.getItem('fl26_ob')) {
  const ob = document.getElementById('ob-banner');
  if (ob) ob.style.display = 'none';
}
// Pulserende hint på første 3 kort
setTimeout(() => {
  if (typeof localStorage !== 'undefined' && !localStorage.getItem('fl26_ob')) {
    document.querySelectorAll('.min-card').forEach((el, i) => {
      if (i < 3) el.classList.add('pulse-hint');
    });
  }
}, 500);
</script>
