    sarligeNetto > 0 ? { label:'Særlige poster (netto)',  val: sarligeNetto, col:'#C8A432' } : null,
    m.udloft   > 0 && sarligeNetto <= 0 ? null : null,
  ].filter(Boolean);

  const negCats = [
    sarligeNetto < 0 ? { label:'Netto særlige poster', val: Math.abs(sarligeNetto), col:'#E87722' } : null,
    m.udloft    < 0 ? { label:'Interne overførsler (neg.)', val: Math.abs(m.udloft), col:'#E24B4A' } : null,
