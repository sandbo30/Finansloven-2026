// Beregn nettoudgifter: drifts + overf + udloft − indt
DATA.forEach(m => { m.total = m.drifts + m.overf + m.udloft - m.indt; });

function scrollToSec(secId) {
  const el = document.getElementById(secId);
  if (el) {
    el.scrollIntoView({behavior:'smooth', block:'start'});
    document.querySelectorAll('.detail-tabs .dtab').forEach(btn => {
      btn.classList.remove('on');
    });
  }
}

// Tilføj ID på sektionerne når detail åbnes
function tagSections(ministerId) {
  const id = ministerId;
  const sectMap = {
    'intro-': '.intro-section',
    'aft-': '.paft-section',
    'flbud-': '.flbud-section',
    'bev-': '.bgrp-section',
    'ctekst-': '.ctekst-section',
  };
  Object.entries(sectMap).forEach(([prefix, cls]) => {
    const el = document.querySelector(`#detail-panel ${cls}`);
    if (el && !el.id) el.id = prefix + id;
  });
}


