//  MINISTRY CHART TOGGLE
// ════════════════════════════════════════════════════════════════
function toggleMinChart(key) {
  minToggles[key] = !minToggles[key];
  const on = minToggles[key];

  // Opdater knap: aktiv = komponenten er MED i diagrammet
  const btn = document.getElementById(key === 'overf' ? 'togOverf' : 'togUdloft');
  if (btn) {
    btn.classList.toggle('on', on);
    const lbl = key === 'overf' ? 'Indkomstoverførsler' : 'Uden for udgiftsloft';
    btn.textContent = (on ? '− ' : '+ ') + lbl;
  }

  // Opdater undertekst
  const sub = document.getElementById('minChartSub');
  if (sub) {
    const parts = ['Driftsudgifter'];
    if (minToggles.overf)  parts.push('indkomstoverførsler');
    if (minToggles.udloft) parts.push('særlige poster');
    const excluded = [];
    if (!minToggles.overf)  excluded.push('indkomstoverførsler');
    if (!minToggles.udloft) excluded.push('særlige poster');
    const exStr = excluded.length ? ` · Ekskl. ${excluded.join(' og ')}` : '';
    sub.textContent = `Mia. kr. · 2026 · Nettoudgifter${exStr} · klik på søjle for detaljer`;
  }

  buildMinChart();
}

function buildMinChart() {
  // Compute each §'s value given current toggle state
  function val(m) {
    // Fuld nettoudgift med mulighed for at fjerne komponenter
    const sarligNetto = (m.udloft || 0) - (m.indt || 0);
    return m.drifts
      + (minToggles.overf  ? m.overf  : 0)
      + (minToggles.udloft ? (sarligNetto > 0 ? sarligNetto : 0) : 0);
  }

  const descending = [...DATA].sort((a, b) => val(b) - val(a));

  if (charts.min) {
    // Update existing chart in-place (no flicker)
    charts.min.data.labels   = descending.map(m => m.para + '  ' + m.shortLabel);
    charts.min.data.datasets[0].data            = descending.map(m => +(val(m) / 1000).toFixed(2));
    charts.min.data.datasets[0].backgroundColor = descending.map(m => AREA_COLORS[m.area] + 'CC');
    charts.min.options.onClick = (e, els) => { if (els.length) selectMin(descending[els[0].index].id); };
    charts.min.options.plugins.tooltip.callbacks.title = items => descending[items[0].dataIndex].full;
    charts.min.options.plugins.tooltip.callbacks.label = ctx => ' ' + fmtTooltip(ctx.parsed.x * 1000);
    charts.min.update('none');
    return;
  }

  // First build
  charts.min = new Chart(document.getElementById('cMin'), {
    type: 'bar',
    data: {
      labels: descending.map(m => m.para + '  ' + m.shortLabel),
      datasets: [{
        data: descending.map(m => +(val(m) / 1000).toFixed(2)),
        backgroundColor: descending.map(m => AREA_COLORS[m.area] + 'CC'),
        borderRadius: 3, borderSkipped: false
      }]
    },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            title: items => descending[items[0].dataIndex].full,
            label: ctx  => ' ' + fmtTooltip(ctx.parsed.x * 1000)
          }
        }
      },
      scales: {
        x: { grid:{color:'rgba(0,0,0,.05)'}, ticks:{ font:{size:11}, callback: v => (+v >= 1 ? (+v).toFixed(0) + ' mia.' : +(v*1000).toFixed(0) + ' mio.') } },
        y: { ticks:{ font:{size:10}, autoSkip:false }, grid:{display:false} }
      },
      onClick: (e, els) => { if (els.length) selectMin(descending[els[0].index].id); },
      onHover:  (e, els) => { e.native.target.style.cursor = els.length ? 'pointer' : 'default'; }
    }
  });
}

