// Formatering til kompakte labels og metrik-kort
function fmt(v, decimals=1) {
  if (v === 0) return '0,0 mia.';
  const b = v / 1000;
  const d = decimals ?? (Math.abs(b) >= 10 ? 1 : Math.abs(b) >= 1 ? 1 : 2);
  return b.toFixed(d).replace('.', ',') + ' mia.';
}

// Formatering til tooltips og tabeller: altid to decimaler og fuld enhed
function fmtTooltip(v) {
  if (v === 0) return '0,00 mia. kr.';
  const b = v / 1000;
  const d = Math.abs(b) >= 10 ? 2 : Math.abs(b) >= 1 ? 2 : 3;
  return b.toFixed(d).replace('.', ',') + ' mia. kr.';
}

// Formatering til underkontitabel
function fmtFull(v) {
  if (v === 0) return '0,0 mia. kr.';
  const b = v / 1000;
  const d = Math.abs(b) >= 10 ? 1 : Math.abs(b) >= 1 ? 1 : 2;
  return b.toFixed(d).replace('.', ',') + ' mia. kr.';
}

function destroyCharts() {
  Object.values(charts).forEach(c => { try { c.destroy(); } catch(e){} });
  charts = {};
}

