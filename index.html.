function partyChip(abbr) {
  const c = PARTY_COLORS[abbr] || {bg:'#888',fg:'#fff'};
  const full = PARTY_FULL[abbr] || abbr;
  return `<span class="party-chip" title="${full}" style="background:${c.bg};color:${c.fg}">${abbr}</span>`;
}

function paftCardHTML(a, idx, prefix) {
  const isForlig = !!a.is_forlig;
  const typeRaw = isForlig ? 'Forlig' : (a.type || 'Aftale');
  const typeClass = 'type-' + typeRaw.replace(/[^a-zA-Z]/g,'').replace('Tillægsaftale','Tillaegsaftale').replace('Delaftale','Delaftale');
  const yearStr = a.year ? String(a.year) : '—';
  const partiesHTML = (a.parties||[]).map(partyChip).join('');
  const subject = a.subject || a.full_text?.substring(0,80) || '—';

  // Udløbsår badge
  let expiresHTML = '';
  if (a.expires) {
    const soon = a.expires <= 2026;
    expiresHTML = `<span class="paft-expires${soon?' soon':''}">Udløber ${a.expires}</span>`;
  }

  // Forlig-markering
  const forligBadge = isForlig ? `<span class="paft-forlig-star">FORLIG</span>` : '';

  const searchIdx = [typeRaw, subject, yearStr, (a.parties||[]).join(' '), a.full_text||''].join(' ').toLowerCase();

  return `<div class="paft-card" id="pc-${prefix}-${idx}"
      data-s="${searchIdx}" data-type="${typeRaw}" data-year="${a.year||0}"
      data-forlig="${isForlig?1:0}"
      onclick="togglePaftCard('${prefix}',${idx})">
    <div class="paft-card-top type-${typeRaw.replace(/[^a-zA-Z]/g,'')}">
      <div class="paft-type-row">
        <span>
          <span class="paft-type-badge type-${typeRaw.replace(/[^a-zA-Z]/g,'')}">${typeRaw}</span>
          ${forligBadge}
        </span>
        <span style="display:flex;gap:5px;align-items:center">
          ${expiresHTML}
          <span class="paft-year">${yearStr}</span>
        </span>
      </div>
      <div class="paft-subject">${subject}</div>
      <div class="paft-parties">${partiesHTML}</div>
    </div>
    <div class="paft-card-body" id="pcb-${prefix}-${idx}">
      <p class="paft-full-text">${a.full_text || subject}</p>
    </div>
  </div>`;
}

function renderPolitiskeAftaler(ministerId) {
  const prefix = String(ministerId).padStart(2,'0');
  const aftaler = AFTALER_DATA[prefix];
  if (!aftaler || !aftaler.length) return '';

  const forligOnly = aftaler.filter(a=>a.is_forlig);
  const others = aftaler.filter(a=>!a.is_forlig);
  const nForlig = forligOnly.length;

  // Typer til filtre
  const types = [...new Set(aftaler.map(a=>a.is_forlig?'Forlig':(a.type||'Aftale')))].sort();
  const years = [...new Set(aftaler.map(a=>a.year).filter(Boolean))].sort((a,b)=>b-a);

  if (!paftState[prefix]) paftState[prefix] = {search:'',typeFilter:'Alle',yearFilter:'Alle',forligOnly:false};

  const typeChips = ['Alle',...types].map(t=>
    `<button class="paft-chip${t==='Alle'?' active':''}" onclick="paftSetFilter('${prefix}','type','${t}')">${t}</button>`
  ).join('');

  // Forlig-filter knap
  const forligChip = nForlig > 0
    ? `<span class="paft-filter-sep"></span>
       <button class="paft-chip" id="paft-fonly-${prefix}" onclick="paftToggleForlig('${prefix}')">
         ★ Kun forlig (${nForlig})
       </button>`
    : '';

  const yearOpts = ['<option value="">Alle år</option>',
    ...years.map(y=>`<option value="${y}">${y}</option>`)
  ].join('');

  const cardsHTML = aftaler.map((a,idx)=>paftCardHTML(a,idx,prefix)).join('');

  const subtitle = nForlig > 0
    ? `${nForlig} gældende forlig · ${others.length} øvrige politiske aftaler`
    : `${aftaler.length} politiske aftaler fra C. Tekstanmærkninger`;

  const sourceNote = nForlig > 0
    ? `<div class="paft-source-note">
        ★ Forlig markeret med <strong>FORLIG</strong> er officielle, gældende politiske forlig pr. 1. oktober 2025 —
        kilde: Finansudvalget, FIU Alm.del, svar på spm. 2
       </div>` : '';

  return `
  <div class="paft-section" id="sec-aft-${prefix}">
    <div class="paft-topbar">
      <div class="paft-topbar-left">
        <div class="paft-icon">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 4h10M3 8h7M3 12h5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <div class="paft-headline">Politiske aftaler</div>
          <div class="paft-sub">${subtitle}</div>
        </div>
      </div>
      <select style="padding:4px 8px;border:1px solid var(--border);border-radius:7px;
        font-size:11px;font-family:inherit;background:var(--bg);color:var(--text);outline:none;"
        onchange="paftSetFilter('${prefix}','year',this.value)">
        ${yearOpts}
      </select>
    </div>
    <div class="paft-toolbar">
      <input class="paft-search" type="text"
        placeholder="Søg på emne, parti eller årstal…"
        oninput="paftSetFilter('${prefix}','search',this.value)"
        id="paftsearch-${prefix}">
      <div class="paft-filter-group" id="paftchips-${prefix}">${typeChips}${forligChip}</div>
    </div>
    ${sourceNote}
    <div class="paft-grid" id="paftgrid-${prefix}">${cardsHTML}</div>
    <div class="paft-empty" id="paftempty-${prefix}">Ingen aftaler matcher søgningen.</div>
    <div class="paft-foot">
      Officielle forlig: Finansudvalget, FIU Alm.del, svar på spm. 2 (pr. 1. oktober 2025) ·
      Øvrige aftaler: Finanslov 2026, C. Tekstanmærkninger, Finansministeriet
    </div>
  </div>`;
}

function togglePaftCard(prefix, idx) {
  const card = document.getElementById(`pc-${prefix}-${idx}`);
  const body = document.getElementById(`pcb-${prefix}-${idx}`);
  if (!card || !body) return;
  const open = body.classList.toggle('open');
  card.classList.toggle('open', open);
}

function paftToggleForlig(prefix) {
  if (!paftState[prefix]) paftState[prefix] = {search:'',typeFilter:'Alle',yearFilter:'Alle',forligOnly:false};
  paftState[prefix].forligOnly = !paftState[prefix].forligOnly;
  const btn = document.getElementById(`paft-fonly-${prefix}`);
  btn?.classList.toggle('active', paftState[prefix].forligOnly);
  applyPaftFilters(prefix);
}

function paftSetFilter(prefix, key, value) {
  if (!paftState[prefix]) paftState[prefix] = {search:'',typeFilter:'Alle',yearFilter:'Alle',forligOnly:false};
  if (key==='type') {
    paftState[prefix].typeFilter = value;
    document.querySelectorAll(`#paftchips-${prefix} .paft-chip`).forEach(btn => {
      if (!btn.id?.includes('fonly')) btn.classList.toggle('active', btn.textContent.trim()===value);
    });
  } else if (key==='year') {
    paftState[prefix].yearFilter = value||'Alle';
  } else if (key==='search') {
    paftState[prefix].search = value.toLowerCase().trim();
  }
  applyPaftFilters(prefix);
}

function applyPaftFilters(prefix) {
  const st = paftState[prefix] || {search:'',typeFilter:'Alle',yearFilter:'Alle',forligOnly:false};
  const grid = document.getElementById(`paftgrid-${prefix}`);
  const empty = document.getElementById(`paftempty-${prefix}`);
  if (!grid) return;
  let anyVisible = false;
  grid.querySelectorAll('.paft-card').forEach(card => {
    const typeMatch = st.typeFilter==='Alle' || card.dataset.type===st.typeFilter;
    const yearMatch = st.yearFilter==='Alle' || card.dataset.year===st.yearFilter;
    const searchMatch = !st.search || (card.dataset.s||'').includes(st.search);
    const forligMatch = !st.forligOnly || card.dataset.forlig==='1';
    const show = typeMatch && yearMatch && searchMatch && forligMatch;
    card.style.display = show?'':'none';
    if (show) anyVisible = true;
  });
  if (empty) empty.style.display = anyVisible?'none':'';
}

