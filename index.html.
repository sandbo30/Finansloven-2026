function toggleCTekst(prefix, idx) {
  const body = document.getElementById(`ctbody-${prefix}-${idx}`);
  const hdr  = document.getElementById(`cti-${prefix}-${idx}`).querySelector('.ctekst-item-hdr');
  const chev = document.getElementById(`ctchev-${prefix}-${idx}`);
  if (!body) return;
  const open = body.classList.toggle('open');
  hdr.classList.toggle('open', open);
  chev.classList.toggle('open', open);
}

function filterCTekst(prefix, cat) {
  ctekstFilter[prefix] = cat;
  // Opdater knapper
  document.querySelectorAll(`#ctcats-${prefix} .ctekst-cat-btn`).forEach(btn => {
    btn.classList.toggle('on', btn.textContent.trim() === (cat==='Alle'?'Alle':cat==='Dispositionsrammer mv'?'Dispositionsrammer':cat));
  });
  applyCtekstFilters(prefix);
}


function showAllCTekst(prefix) {
  const list = document.getElementById('ctlist-' + prefix);
  const btn  = document.getElementById('ctmore-' + prefix);
  if (!list) return;
  list.querySelectorAll('.ctekst-item.ct-hidden').forEach(el => el.classList.remove('ct-hidden'));
  if (btn) btn.style.display = 'none';
}

function initCTekstLimit(prefix, limit) {
  const list = document.getElementById('ctlist-' + prefix);
  if (!list) return;
  const items = list.querySelectorAll('.ctekst-item');
  items.forEach((el, i) => {
    if (i >= limit) el.classList.add('ct-hidden');
  });
}

function searchCTekst(prefix, q) {
  applyCtekstFilters(prefix, q.toLowerCase().trim());
}

function applyCtekstFilters(prefix, q) {
  q = q || '';
  const cat = ctekstFilter[prefix] || 'Alle';
  const list = document.getElementById(`ctlist-${prefix}`);
  const empty = document.getElementById(`ctempty-${prefix}`);
  if (!list) return;
  
  let anyVisible = false;
  if (q || cat !== 'Alle') list.classList.add('show-all');
  list.querySelectorAll('.ctekst-item').forEach(item => {
    const itemCat = item.dataset.cat || '';
    const catMatch = cat==='Alle' || itemCat===cat || itemCat.startsWith(cat);
    const searchMatch = !q || (item.dataset.s||'').includes(q);
    const show = catMatch && searchMatch;
    item.style.display = show ? '' : 'none';
    if (show) anyVisible = true;
  });
  if (empty) empty.style.display = (!anyVisible && (q || cat!=='Alle')) ? '' : 'none';
}

